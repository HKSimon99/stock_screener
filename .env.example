# Copy this file to `.env` for shared defaults.
# Put machine-specific overrides in `.env.local` (gitignored), especially if
# you want the backend to use a local Postgres database instead of Neon.
#
# ── Database ──────────────────────────────────────────────
# Direct endpoint — Alembic migrations use this (session DDL unsafe through pooler)
POSTGRES_HOST=localhost
# Neon only: pooled endpoint (insert -pooler before region in the hostname).
# Leave empty for local dev / non-Neon Postgres.
POSTGRES_HOST_POOLER=
# Optional: Neon read-replica compute endpoint for GET-heavy API traffic.
# Leave empty unless you've created a read replica in Neon.
POSTGRES_HOST_REPLICA=
POSTGRES_PORT=5432
POSTGRES_DB=consensus
POSTGRES_SCHEMA=consensus_app
POSTGRES_USER=consensus
POSTGRES_PASSWORD=changeme

# Optional: DB promotion helpers for backend/promote_local_to_neon.py
# Use a fresh Neon branch direct URL as the target when promoting local -> Neon.
PROMOTION_SOURCE_DATABASE_URL=
PROMOTION_TARGET_DATABASE_URL=
PROMOTION_SCHEMA=consensus_app
PROMOTION_DUMP_FILE=
PROMOTION_RESTORE_JOBS=4

# ── Celery ────────────────────────────────────────────────
# Local dev (no Redis needed): leave blank → auto-uses PostgreSQL as broker
# Production (Redis): uncomment and set:
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Redis ─────────────────────────────────────────────────
# Optional — only needed for production caching (market regime, rankings)
# REDIS_URL=redis://localhost:6379/0

# ── Clerk Authentication ──────────────────────────────────
# Sign up at https://clerk.com — free up to 10K MAU
# From Clerk dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Optional: customize sign-in/sign-up URL paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app

# ── FastAPI ───────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
API_V1_PREFIX=/api/v1

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins. Dev default: localhost:3000
# Production example: CORS_ORIGINS=https://yourapp.vercel.app,https://yourapp.com
CORS_ORIGINS=http://localhost:3000

# ── API Key Authentication (optional) ─────────────────────
# Comma-separated list of accepted API keys for admin endpoints.
# Leave empty to disable auth (dev default).
# Example: API_KEYS=key-abc-123,key-def-456
API_KEYS=

# ── US Data — all free ────────────────────────────────────
# yfinance uses no API key; SEC EDGAR uses no API key
# FMP free tier (250 req/day) — optional backup
FMP_API_KEY=

# FRED (Federal Reserve) for US risk-free rate
FRED_API_KEY=

# ── KR Data ───────────────────────────────────────────────
# KIS Developers (Korea Investment & Securities) — free with account
# Register at: https://apiportal.koreainvestment.com/
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
# Set to 'paper' for paper trading env, 'real' for live
KIS_ENV=paper

# OpenDART — free, register at: https://opendart.fss.or.kr/
OPENDART_API_KEY=
