{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend-api",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "--directory", "backend", "uvicorn", "app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 3000
    },
    {
      "name": "celery-worker",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "--directory", "backend", "celery", "-A", "app.tasks.celery_app.celery_app", "worker", "--loglevel=info", "--pool=solo"],
      "port": 8001,
      "autoPort": true
    },
    {
      "name": "celery-beat",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "--directory", "backend", "celery", "-A", "app.tasks.celery_app.celery_app", "beat", "--loglevel=info"],
      "port": 8002,
      "autoPort": true
    }
  ]
}
